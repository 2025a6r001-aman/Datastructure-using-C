#include <stdio.h>

int main()
{
    int n;
    printf("Enter number of students: ");
    scanf("%d",&n);

    int students[n], sandwiches[n];
    int count1 = 0, count2 = 0;

    printf("Enter students preferences (0 or 1):\n");
    for(int i=0;i<n;i++)
    {
        scanf("%d",&students[i]);

        if(students[i] == 0)
            count1++;
        else
            count2++;
    }

    printf("Enter sandwiches stack:\n");
    for(int i=0;i<n;i++)
    {
        scanf("%d",&sandwiches[i]);
    }

    for(int i=0;i<n;i++)
    {
        if(sandwiches[i] == 0)
        {
            if(count1 == 0)
                break;
            count1--;
        }
        else
        {
            if(count2 == 0)
                break;
            count2--;
        }
    }

    printf("Students unable to eat: %d", count1+ count2);

    return 0;
}
