#include<stdio.h>
#include<string.h>
#include<math.h>
#include<ctype.h>
#include<stdlib.h>
int precedence(char opr){
    switch(opr){
        case '+':
        case '-':
           return 1;
           case '*':
           case '/':
             return 2;
             case '^':
             return 3;
             default:
             return 0;
    }
}
char* convertInfixToPostfix(char* infixExp){
    int len = strlen(infixExp), top =-1, x=0;
    char *postfix = (char*) malloc(len+1);//output string
    char operator[len];// stack
    for(int i=0;i<len;i++){
        char ch = infixExp[i];
        if(isalnum(ch)){
            postfix[x++]= ch;

        }
        else if(ch == '+'|| ch == '-'|| ch == '*'|| ch == '/'|| ch == '^'){
            while(top != -1 && precedence(ch)<=precedence(operator[top])&& ch != '^'){// if one ondiion is false in case of and conditio got false and loop wont run
                postfix[x++] = operator[top--];
            }
            operator[++top]= ch;

        }
        else if(ch == '('){
            operator[++top] = ch;

        }
        else if(ch == ')'){
            while(operator[top] != '('){
                postfix[x++] = operator[top--];// last operator got popped
            }
            top--;//  for bracket removal

        }
    }
    while(top != -1){
        postfix[x++]= operator[top--];
    }
    postfix[x] = '\0';// string is terminated by null character
    return postfix;

   
}
int main(){
    char expr[100];
    printf("Enter Infix Expression: ");
    gets(expr);
    printf("Postfix Expression is= %s\n", convertInfixToPostfix(expr));

    return 0;
}
