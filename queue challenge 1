#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
int N ;
int Queue[100], front =-1, rear=-1;
int isFull(){
    return rear == N-1;

}
int isEmpty(){
    return front ==-1;

}
void enqueue(int data){
    if(isFull()){
        printf("Queue Overflow\n");
        return;

    }
    Queue[++rear] = data;
    if(front == -1)
       front = rear;

}
int dequeue(){
    if(isEmpty()){
        printf("Queue Underflow\n");
        return -1;
    }
    int val=Queue[front++];
    if(front>rear)
        front = rear = -1;
    return val;

}
int peek(){
    if(isEmpty()){
        printf("Queue Underflow\n");
        return -1;
    }
    return Queue[front];

}
void display(){
    if(isEmpty()){
        printf("Queue is Empty\n");
        return;

    }
    for(int i=front;i<=rear;i++){
        printf("%d ",Queue[i]);
    }
    printf("\n");
    
}
int main(){
    int choice,val,res,data;
    scanf("%d",&N);
    scanf("%d",&val);
    while(val!=0){
    scanf("%d", &choice);
    switch(choice){
            case 1:
                scanf("%d", &data);
                enqueue(data);
                break;
            case 2: 
                res = dequeue();
                if(res != -1)
                    printf("%d \n", res);
                break;
            case 3: 
              res = peek();
              if(res != -1)
                 printf("%d \n",res);
            break;   
            case 4: 
                display();
                break;
        }
        val--;
    }
    
    return 0;
}
 
